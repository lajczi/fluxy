{
  "name": "fluxer-mod-bot",
  "version": "2.0.0",
  "description": "Fluxy moderation and server-management bot for Fluxer with an optional dashboard",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc && tsc-alias && cp -r src/assets build/ && cp -r src/locales build/",
    "build:clean": "rimraf build/ && npm run build",
    "start": "node build/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "i18n:check": "tsx scripts/validate-locales.ts",
    "crowdin:consolidate": "tsx scripts/consolidate-crowdin-locales.ts",
    "pm2:start": "pm2 start ecosystem.config.js --only fluxer-mod-bot",
    "pm2:stop": "pm2 stop fluxer-mod-bot",
    "pm2:restart": "pm2 restart fluxer-mod-bot",
    "pm2:logs": "pm2 logs fluxer-mod-bot",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tests/tsconfig.json"
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!string-strip-html)"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/moderation-bot/",
      "<rootDir>/documentation/",
      "<rootDir>/fluxy-docs-main/",
      "<rootDir>/tscord/"
    ],
    "forceExit": true
  },
  "keywords": [
    "fluxer",
    "moderation",
    "bot",
    "chatbot"
  ],
  "author": "",
  "license": "Elastic-2.0",
  "dependencies": {
    "@dr.pogodin/csurf": "^1.16.9",
    "@erinjs/core": "^1.2.4",
    "@erinjs/types": "^1.2.4",
    "@erinjs/ws": "^1.2.4",
    "@napi-rs/canvas": "^0.1.97",
    "@sentry/node": "^10.47.0",
    "@types/compression": "^1.8.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "fast-xml-parser": "^5.5.12",
    "helmet": "^8.1.0",
    "html-to-text": "^9.0.5",
    "mongoose": "^9.4.1",
    "node-cron": "^4.2.1",
    "pidusage": "^4.0.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/html-to-text": "^9.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/pidusage": "^2.0.5",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
